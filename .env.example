# MJR-EHR Configuration
# Copy this file to .env and fill in values

# ==========================================
# SERVER
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# AI / LLM
# ==========================================
# Set to 'api' to enable Claude integration, 'mock' for pattern matching only
AI_MODE=mock
ANTHROPIC_API_KEY=

# Set to 'false' to disable LLM-augmented CDS entirely
LLM_CDS_ENABLED=true

# ==========================================
# VOICE / ASR
# ==========================================
# Options: 'browser' (default), 'deepgram', 'whisper'
ASR_PROVIDER=browser
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# ==========================================
# COMMUNICATIONS
# ==========================================
# Twilio (SMS + Voice + Video)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourpractice.com

# ==========================================
# BILLING
# ==========================================
# Options: 'none', 'change_healthcare', 'waystar', 'office_ally'
CLEARINGHOUSE=none
CLEARINGHOUSE_API_KEY=

# Practice information
PROVIDER_NPI=1234567890
TAX_ID=12-3456789
PRACTICE_NAME=Your Practice Name
PRACTICE_PHONE=555-555-0100
PRACTICE_ADDRESS=123 Medical Center Dr, City, ST 12345

# ==========================================
# AUTHENTICATION (JWT)
# ==========================================
# IMPORTANT: Generate a strong random secret for production
# Example: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_BEFORE_PRODUCTION
JWT_EXPIRY=8h

# ==========================================
# DATABASE
# ==========================================
# SQLite database path (auto-created on first run)
DATABASE_PATH=./data/mjr-ehr.db
